{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User preferences and metadata.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique identifier for the user" },
        "preferences": {
          "type": "object",
          "properties": {
            "priorityAlerts": { "type": "boolean" },
            "globalConcierge": { "type": "boolean" },
            "enhancedSecurity": { "type": "boolean" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "Request": {
      "title": "Concierge Request",
      "description": "A luxury concierge service request from a client.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Client user ID if logged in" },
        "name": { "type": "string", "description": "Client full name" },
        "email": { "type": "string", "format": "email", "description": "Client email address" },
        "phone": { "type": "string", "description": "Client phone number" },
        "service": { "type": "string", "description": "Event or service of interest" },
        "message": { "type": "string", "description": "Specific requirements" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "CANCELLED"], "description": "Current status of the request" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["name", "email", "service"]
    }
  },
  "firestore": {
    "requests/{requestId}": {
      "schema": "Request",
      "description": "Collection of concierge requests."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "User settings and profile data."
    }
  }
}
